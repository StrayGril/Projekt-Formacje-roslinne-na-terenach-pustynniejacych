    "import sys\n",
    "import os\n",
    "\n",
    "# Dodanie katalogu głównego repo do ścieżki\n",
    "sys.path.append(os.path.abspath(\"..\"))\n",
    "\n",
    "import numpy as np\n",
    "from pipeline.model_core import dimensional_to_dimensionless, homogeneous_state\n",
    "from pipeline.turing_instability import turing_analysis\n",
    "from pipeline.pattern_visualization import simulate_patterns, plot_patterns\n",
    "\n",
    "# Z modelu Klausmeieera [np.float64(0.9374999999999999), np.float64(1.8749999999999998)] 0.45 62.5 0.0625\n",
    "# Parametry\n",
    "Lx = 60\n",
    "N = 100\n",
    "av = [0.9036, 1.9277, 2.9518, 3.9759, 5]\n",
    "mvals = [0.3, 0.45, 0.5]\n",
    "d1 = 62.5\n",
    "d2 = 0.0625\n",
    "# Rysowanie wzorow na powyższych parametrach\n",
    "for a in av:\n",
    "    for m in mvals:\n",
    "        print(\"a = \", a, \", m = \", m)\n",
    "        wynik = simulate_patterns(a, m, d1, d2, Lx, Lx, N, N, T = 10000, verbose=True)\n",
    "        plot_patterns(wynik, wykres = \"v\")\n"
   ]
  },
